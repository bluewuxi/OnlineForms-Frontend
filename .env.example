VITE_API_BASE_URL=https://form-api.kidrawer.com/v1
VITE_PUBLIC_TENANT_CODES=std-school
VITE_AUTH_MODE=mock
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REDIRECT_URI=
VITE_COGNITO_SCOPE=openid profile email
VITE_COGNITO_TOKEN_USE=access

# FS-04: Cloudflare Turnstile CAPTCHA (public enrollment form anti-bot protection)
# Set to false in local/test environments to skip the widget.
VITE_TURNSTILE_ENABLED=true
# Cloudflare Turnstile site key (obtain from the Cloudflare dashboard).
# Use the test site key 1x00000000000000000000AA for development.
VITE_TURNSTILE_SITE_KEY=


